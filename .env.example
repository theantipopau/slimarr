# Slimarr Docker environment example
#
# Copy this file to .env next to docker-compose.yml and fill in the values for
# your services. Values here override config.yaml inside the container.

# Web UI
SLIMARR_PORT=9494
SLIMARR_LOG_LEVEL=info
SLIMARR_LOG_FORMAT=plain
TZ=UTC

# Plex
SLIMARR_PLEX_URL=http://plex:32400
SLIMARR_PLEX_TOKEN=

# Download client: sabnzbd or nzbget
SLIMARR_DOWNLOAD_CLIENT=sabnzbd
SLIMARR_SABNZBD_URL=http://sabnzbd:8080
SLIMARR_SABNZBD_API_KEY=
SLIMARR_NZBGET_URL=http://nzbget:6789
SLIMARR_NZBGET_USERNAME=
SLIMARR_NZBGET_PASSWORD=

# Indexers
SLIMARR_PROWLARR_URL=http://prowlarr:9696
SLIMARR_PROWLARR_API_KEY=

# Optional Arr integrations
SLIMARR_RADARR_URL=http://radarr:7878
SLIMARR_RADARR_API_KEY=
SLIMARR_SONARR_URL=http://sonarr:8989
SLIMARR_SONARR_API_KEY=

# Metadata
SLIMARR_TMDB_API_KEY=

# Optional auth overrides. Leave blank to let Slimarr generate local secrets.
SLIMARR_SECRET_KEY=
SLIMARR_API_KEY=

# Optional SQLite path override. The Docker image defaults this to /app/data/slimarr.db.
# SLIMARR_DB=/app/data/slimarr.db

# Optional PostgreSQL backend for write-heavy deployments.
# SLIMARR_DB_URL=postgresql+asyncpg://slimarr:change_me@postgres:5432/slimarr
# SLIMARR_DB_POOL_SIZE=10
# SLIMARR_DB_MAX_OVERFLOW=20
# SLIMARR_DB_POOL_TIMEOUT=30
# SLIMARR_DB_POOL_RECYCLE=1800

# Traefik compose template only.
SLIMARR_HOST=slimarr.example.com
